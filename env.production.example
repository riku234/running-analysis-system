# 本番環境用環境変数
# セキュリティ上重要: 実際の値は安全な方法で管理してください

# アプリケーション設定
NODE_ENV=production
APP_ENV=production
APP_NAME=running-analysis-system

# ドメイン設定（実際のドメインに変更してください）
DOMAIN=your-domain.com
API_URL=https://your-domain.com

# データベース設定（必要に応じて）
# DATABASE_URL=postgresql://user:password@localhost:5432/running_analysis

# ファイルアップロード設定（t3.small向けに制限）
MAX_FILE_SIZE=50MB
UPLOAD_PATH=/opt/running-analysis/uploads

# ログ設定
LOG_LEVEL=INFO
LOG_PATH=/opt/running-analysis/logs

# セキュリティ設定
# SECRET_KEY=your-secret-key-here
# JWT_SECRET=your-jwt-secret-here

# SSL設定
SSL_CERT_PATH=/opt/running-analysis/ssl-certs/fullchain.pem
SSL_KEY_PATH=/opt/running-analysis/ssl-certs/privkey.pem

# バックアップ設定
BACKUP_PATH=/opt/backups
BACKUP_RETENTION_DAYS=7

# モニタリング設定
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10

# 外部サービス（必要に応じて）
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=ap-northeast-1
# S3_BUCKET=your-s3-bucket

# Redis設定（必要に応じて）
# REDIS_URL=redis://localhost:6379

# メール設定（必要に応じて）
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password 